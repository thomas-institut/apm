{
  "name": "thomas-institut/ape-backend",
  "description": "description",
  "version": "0.1.0",
  "minimum-stability": "stable",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Rafael Nájera",
      "email": "rafael.najera@uni-koeln.de"
    }
  ],
  "repositories": [
    {
      "type": "path",
      "url": "../shared-php",
      "options": {
        "symlink": false
      }
    }
  ],
  "scripts" : {
    "test": "./vendor/bin/phpunit --display-all-issues",
    "test:coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --display-all-issues --coverage-filter src/ThomasInstitut --coverage-text --coverage-html build/coverage"
  },
  "require": {
    "php": "^8.3",
    "ext-yaml": "*",
    "thomas-institut/shared-php": "dev-main#8dd8006c861b60b9d5e813b4af6d5796d557e875",
    "slim/slim": "^4.15",
    "thomas-institut/datatable" : "^2.0",
    "thomas-institut/timestring" : "^v1.3",
    "monolog/monolog": "^3.10",
    "php-di/php-di": "^7.1",
    "slim/psr7": "^1.8"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5"
  },
  "autoload": {
    "psr-4": {
      "ThomasInstitut\\": "src/ThomasInstitut/"
    }
  }
}