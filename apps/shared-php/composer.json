{
  "name": "thomas-institut/shared-php",
  "description": "Shared PHP library for Thomas Institut",
  "version": "0.1.0",
  "minimum-stability": "stable",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Rafael Nájera",
      "email": "rafael.najera@uni-koeln.de"
    }
  ],
  "scripts" : {
    "test": "./vendor/bin/phpunit --display-all-issues",
    "test:coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --display-all-issues --coverage-filter src --coverage-text --coverage-html build/coverage"
  },
  "require": {
    "php": "^8.3",
    "ext-yaml": "*",
    "slim/slim": "^4.15",
    "monolog/monolog": "^3.10",
    "php-di/php-di": "^7.1",
    "slim/psr7": "^1.8",
    "ext-pdo": "*",
    "ext-posix": "*",
    "ext-pcntl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5"
  },
  "autoload": {
    "psr-4": {
      "ThomasInstitut\\": "src/ThomasInstitut/"
    }
  }
}